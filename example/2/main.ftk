const::char GLOBAL = 'G';

pub int main() {
    let::int x = 14;
    var::str y = "hi";
    const::char f = 'f';
    
    sendln!(x);
    sendln!(y);
    sendln!(f);
    sendln!(GLOBAL);
    
    y = "hello";
    sendln!(y);
    
    return 0;
}

int fl() {
    const::int x = 14;
    sendln!(x);
    return 0;
}